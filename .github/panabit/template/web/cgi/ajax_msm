#!/bin/sh

. ../../common/ajax_common

APPNAME="msm"
WORKDIR="${DATAPATH}/${APPNAME}"
CONFDIR="${PGETC}/App/${APPNAME}"
APPCONF="${CONFDIR}/app.conf"
APPCTRL="/usr/ramdisk/app/${APPNAME}/appctrl"

if [ ! -x "${APPCTRL}" ]; then
  APPCTRL="${PGPATH}/app/${APPNAME}/appctrl"
fi

escape_log_lines()
{
  awk '{
    gsub(/\033\[[0-9;]*[A-Za-z]/, "");
    gsub(/\\/, "\\\\");
    gsub(/"/, "\\\"");
    gsub(/\t/, "\\t");
    gsub(/\r/, "\\r");
    gsub(/[\001-\010\013\014\016-\037]/, "");
    printf "%s\\n", $0
  }'
}

find_logfile()
{
  set -- \
    "${WORKDIR}/logs/msm.log" \
    "${WORKDIR}/logs/server.log" \
    "${WORKDIR}/logs/web.log" \
    "${WORKDIR}/logs"/*.log \
    "/root/.msm/logs/msm.log" \
    "/root/.msm/logs/server.log" \
    "/root/.msm/logs/web.log" \
    "/root/.msm/logs"/*.log

  for log_file in "$@"; do
    [ -f "${log_file}" ] || continue
    printf '%s\n' "${log_file}"
    return 0
  done

  return 1
}

read_log_content()
{
  tail -200 "$1" 2>/dev/null | escape_log_lines
}

status_payload()
{
  "${APPCTRL}" status_json
}

submit_config()
{
  mkdir -p "${CONFDIR}"
  printf 'status=%s\n' "${CGI_status}" > "${APPCONF}"

  if [ "${CGI_status}" = "enable" ]; then
    "${APPCTRL}" start >/dev/null 2>&1
  else
    "${APPCTRL}" stop >/dev/null 2>&1
  fi

  retjson 0 "保存成功"
}

start_service()
{
  "${APPCTRL}" start >/dev/null 2>&1
  retjson 0 "启动成功"
}

stop_service()
{
  "${APPCTRL}" stop >/dev/null 2>&1
  retjson 0 "停止成功"
}

restart_service()
{
  "${APPCTRL}" restart >/dev/null 2>&1
  retjson 0 "重启成功"
}

get_log()
{
  LOGFILE="$(find_logfile || true)"

  if [ -n "${LOGFILE}" ]; then
    log_content="$(read_log_content "${LOGFILE}")"
    if [ -z "${log_content}" ]; then
      log_content="日志为空"
    fi
  else
    log_content="未找到日志文件，已检查 ${WORKDIR}/logs 和 /root/.msm/logs"
  fi

  printf '{"log_content":"%s","log_file":"%s"}' "${log_content}" "${LOGFILE}"
}

case "${CGI_action}" in
  "load_config")
    retjson 0 "OK" "`status_payload`"
    ;;
  "submit_config")
    action_check
    submit_config
    ;;
  "start_service")
    action_check
    start_service
    ;;
  "stop_service")
    action_check
    stop_service
    ;;
  "restart_service")
    action_check
    restart_service
    ;;
  "get_log")
    retjson 0 "OK" "`get_log`"
    ;;
  *)
    retjson 1 "UNKNOW_ACTION"
    ;;
esac
